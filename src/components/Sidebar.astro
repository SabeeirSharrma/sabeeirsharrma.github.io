---
import { getCollection } from 'astro:content';

export interface Props {
  project: string;
}

const { project } = Astro.props;
const currentPath = Astro.url.pathname;

// Fetch all docs and filter by the current project
const allDocs = await getCollection('docs');
const projectDocs = allDocs.filter((doc: any) => doc.id.startsWith(`${project}/`) || doc.id === project);

// Sort by order if provided in frontmatter, else alphabetically by title
projectDocs.sort((a: any, b: any) => {
  const orderA = a.data.order ?? 999;
  const orderB = b.data.order ?? 999;
  if (orderA !== orderB) {
    return orderA - orderB;
  }
  return a.data.title.localeCompare(b.data.title);
});

// Build links from entry IDs
// With glob loader, id is like "cpac/installation" (no .md extension)
// We want links like /cpac/docs/installation or /cpac/docs for index
function buildLink(docId: string): string {
  // Handle case where index.md id is just the project name (no slash)
  if (!docId.includes('/')) {
    return `/${docId}/docs`;
  }
  const parts = docId.split('/');
  const proj = parts[0];
  const rest = parts.slice(1).join('/');
  // index page → /project/docs
  if (rest === 'index' || rest === '') {
    return `/${proj}/docs`;
  }
  return `/${proj}/docs/${rest}`;
}

function isActive(link: string): boolean {
  const normalized = currentPath.replace(/\/$/, '');
  const normalizedLink = link.replace(/\/$/, '');
  return normalized === normalizedLink;
}
---

<aside class="sidebar">
  <div class="sidebar-header">
    <div class="sidebar-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
      </svg>
    </div>
    <h3>{project.toUpperCase()} Docs</h3>
  </div>
  
  <nav class="sidebar-nav">
    <ul>
      {projectDocs.map((doc: any) => {
        const link = buildLink(doc.id);
        const active = isActive(link);
        return (
          <li>
            <a 
              href={link}
              class:list={['sidebar-link', { active }]}
            >
              <span class="link-indicator"></span>
              {doc.data.title}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>

  <div class="sidebar-footer">
    <a href={`/${project}`} class="back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Back to {project.toUpperCase()}
    </a>
  </div>
</aside>

<style>
  .sidebar {
    width: 260px;
    flex-shrink: 0;
    position: sticky;
    top: 5rem;
    align-self: flex-start;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    display: none;
    flex-direction: column;
    gap: 1.5rem;
    padding-right: 1.5rem;
    border-right: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .sidebar {
      display: flex;
    }
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .sidebar-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--color-cinder-dark);
    border-radius: 8px;
    color: var(--color-ember-core);
  }

  .sidebar-header h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--color-primary-text);
    letter-spacing: 0.15em;
    margin: 0;
  }

  .sidebar-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    color: var(--color-muted-text);
    text-decoration: none;
    font-size: 0.875rem;
    transition: all 0.2s ease;
    position: relative;
  }

  .sidebar-link:hover {
    background: var(--color-surface);
    color: var(--color-primary-text);
  }

  .sidebar-link.active {
    background: var(--color-cinder-dark);
    color: var(--color-ember-light);
    font-weight: 600;
  }

  .link-indicator {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-border);
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .sidebar-link:hover .link-indicator {
    background: var(--color-ember-core);
    box-shadow: 0 0 8px var(--color-ember-core);
  }

  .sidebar-link.active .link-indicator {
    background: var(--color-ember-core);
    box-shadow: 0 0 10px var(--color-ember-core);
  }

  .sidebar-footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-muted-text);
    text-decoration: none;
    font-size: 0.8rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-ember-light);
  }
</style>
