---
import MainLayout from "./MainLayout.astro";
import Sidebar from "../components/Sidebar.astro";

export interface Props {
  title: string;
  description?: string;
  project: string;
}

const { title, description, project } = Astro.props;
---

<MainLayout
  title={`${title} — ${project.toUpperCase()} Docs`}
  description={description}
>
  <div class="docs-wrapper">
    <Sidebar project={project} />
    <article class="docs-content">
      <div class="docs-header">
        <div class="breadcrumbs">
          <a href="/">Home</a>
          <span class="sep">/</span>
          <a href={`/${project}`}>{project.toUpperCase()}</a>
          <span class="sep">/</span>
          <span class="current">{title}</span>
        </div>
        <h1 class="docs-title">{title}</h1>
        {description && <p class="docs-description">{description}</p>}
      </div>
      <div class="docs-body">
        <slot />
      </div>
    </article>
  </div>
</MainLayout>

<style is:global>
  .docs-wrapper {
    display: flex;
    gap: 2rem;
    max-width: 80rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .docs-content {
    flex: 1;
    min-width: 0;
    max-width: 52rem;
  }

  /* Breadcrumbs */
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    margin-bottom: 1.5rem;
  }
  .breadcrumbs a {
    color: var(--color-muted-text);
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumbs a:hover {
    color: var(--color-ember-light);
  }
  .breadcrumbs .sep {
    color: var(--color-border);
  }
  .breadcrumbs .current {
    color: var(--color-ember-core);
  }

  /* Header */
  .docs-header {
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }
  .docs-title {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    color: var(--color-primary-text);
    margin: 0 0 0.5rem 0;
    letter-spacing: 0.05em;
  }
  .docs-description {
    color: var(--color-muted-text);
    font-size: 1.1rem;
    margin: 0;
  }

  /* ============================
     Markdown Body Styling 
     ============================ */
  .docs-body h1,
  .docs-body h2,
  .docs-body h3,
  .docs-body h4 {
    font-family: var(--font-heading);
    color: var(--color-primary-text);
    letter-spacing: 0.04em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .docs-body h1 {
    font-size: 2rem;
  }
  .docs-body h2 {
    font-size: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .docs-body h3 {
    font-size: 1.25rem;
  }

  .docs-body p {
    color: var(--color-muted-text);
    line-height: 1.8;
    margin: 1rem 0;
  }

  .docs-body a {
    color: var(--color-ember-light);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .docs-body a:hover {
    color: var(--color-ember-glow);
  }

  .docs-body strong {
    color: var(--color-primary-text);
  }

  /* Inline code */
  .docs-body code {
    background: var(--color-surface);
    color: var(--color-ember-light);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    border: 1px solid var(--color-border);
  }

  /* Code blocks */
  .docs-body pre {
    background: var(--color-surface) !important;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    position: relative;
  }
  .docs-body pre code {
    background: none;
    border: none;
    padding: 0;
    color: var(--color-primary-text);
    font-size: 0.875rem;
    line-height: 1.7;
  }

  /* Lists */
  .docs-body ul,
  .docs-body ol {
    color: var(--color-muted-text);
    padding-left: 1.5rem;
    margin: 1rem 0;
    line-height: 1.8;
  }
  .docs-body li {
    margin: 0.4rem 0;
  }
  .docs-body li::marker {
    color: var(--color-ember-core);
  }

  /* Blockquotes */
  .docs-body blockquote {
    border-left: 3px solid var(--color-cinder-mid);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--color-surface);
    border-radius: 0 8px 8px 0;
  }
  .docs-body blockquote p {
    color: var(--color-muted-text);
    font-style: italic;
  }

  /* Tables */
  .docs-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }
  .docs-body th {
    background: var(--color-surface);
    color: var(--color-primary-text);
    font-family: var(--font-heading);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 2px solid var(--color-cinder-mid);
  }
  .docs-body td {
    padding: 0.75rem 1rem;
    color: var(--color-muted-text);
    border-bottom: 1px solid var(--color-border);
  }
  .docs-body tr:hover td {
    background: var(--color-surface);
  }

  /* Horizontal rules */
  .docs-body hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  /* Images */
  .docs-body img {
    border-radius: 10px;
    border: 1px solid var(--color-border);
    max-width: 100%;
  }

  .docs-body pre {
    position: relative;
  }

  .code-copy-btn {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: 0.35rem 0.6rem;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-muted-text);
    cursor: pointer;
    opacity: 0;
    transition:
      opacity 0.2s ease,
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease,
      transform 0.15s ease;
    z-index: 10;
    font-size: 0.75rem;
    font-family: var(--font-body);
    letter-spacing: 0.04em;
  }

  .docs-body pre:hover .code-copy-btn {
    opacity: 1;
  }

  .code-copy-btn:hover {
    background: var(--color-elevated);
    color: var(--color-primary-text);
    border-color: var(--color-cinder-mid);
  }

  .code-copy-btn:active {
    transform: scale(0.94);
  }

  .code-copy-btn.copied {
    opacity: 1;
    color: #4ade80;
    border-color: #4ade8040;
    background: #4ade8012;
  }

  .code-copy-btn .copy-icon,
  .code-copy-btn .check-icon {
    width: 14px;
    height: 14px;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .code-copy-btn .check-icon {
    display: none;
  }

  .code-copy-btn.copied .copy-icon {
    display: none;
  }

  .code-copy-btn.copied .check-icon {
    display: block;
  }
</style>

<script>
  declare const lucide: { createIcons: () => void } | undefined;

  function initCopyButtons() {
    const codeBlocks = document.querySelectorAll(".docs-body pre");

    codeBlocks.forEach((pre) => {
      // Don't add duplicate buttons
      if (pre.querySelector(".code-copy-btn")) return;

      const btn = document.createElement("button");
      btn.className = "code-copy-btn";
      btn.setAttribute("aria-label", "Copy code");
      btn.setAttribute("title", "Copy");
      btn.innerHTML = `
        <i data-lucide="copy" class="copy-icon"></i>
        <i data-lucide="check" class="check-icon"></i>
        <span class="copy-label">Copy</span>
      `;

      btn.addEventListener("click", async () => {
        const code = pre.querySelector("code");
        if (!code) return;

        // Get the raw text and strip leading $ prompts from each line
        let text = code.innerText || code.textContent || "";
        text = text
          .split("\n")
          .map((line) => line.replace(/^\s*\$\s?/, ""))
          .join("\n")
          .trimEnd();

        try {
          await navigator.clipboard.writeText(text);

          // Visual feedback
          btn.classList.add("copied");
          const label = btn.querySelector(".copy-label");
          if (label) label.textContent = "Copied!";

          setTimeout(() => {
            btn.classList.remove("copied");
            if (label) label.textContent = "Copy";
          }, 2000);
        } catch (err) {
          console.error("Failed to copy:", err);
        }
      });

      pre.appendChild(btn);
    });

    // Initialize Lucide icons for the newly added buttons
    if (typeof lucide !== "undefined") {
      lucide.createIcons();
    }
  }

  // Run on initial load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCopyButtons);
  } else {
    initCopyButtons();
  }

  // Re-run after Astro page transitions (View Transitions)
  document.addEventListener("astro:page-load", initCopyButtons);
</script>
