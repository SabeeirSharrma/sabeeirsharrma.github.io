---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection, render } from 'astro:content';

const allDocs = await getCollection('docs');
const privacyDoc = allDocs.find(doc => doc.id === 'PrivacyPolicy');
if (!privacyDoc) throw new Error('Privacy doc not found');

const { Content } = await render(privacyDoc);
---

<MainLayout title="Privacy Policy" description="How The Cinder Project handles your data.">
  <div class="container mx-auto px-4 py-16 max-w-3xl">
    <article class="legal-page">
      <Content />
    </article>
  </div>
</MainLayout>

<style>
  .legal-page {
    color: var(--color-primary-text);
    font-family: var(--font-body);
    line-height: 1.8;
  }
  .legal-page :global(h1) {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .legal-page :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-ember-core);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .legal-page :global(h3) {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary-text);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .legal-page :global(p) {
    margin-bottom: 1rem;
    color: var(--color-muted-text);
  }
  .legal-page :global(ul), .legal-page :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .legal-page :global(li) {
    margin-bottom: 0.4rem;
    color: var(--color-muted-text);
  }
  .legal-page :global(a) {
    color: var(--color-ember-light);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s;
  }
  .legal-page :global(a:hover) {
    color: var(--color-ember-core);
  }
  .legal-page :global(strong) {
    color: var(--color-primary-text);
    font-weight: 600;
  }
  .legal-page :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }
  .legal-page :global(code) {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.85em;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.15em 0.4em;
    color: var(--color-ember-light);
  }
  .legal-page :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  .legal-page :global(th), .legal-page :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.6rem 0.8rem;
    text-align: left;
  }
  .legal-page :global(th) {
    background: var(--color-card);
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-primary-text);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
  .legal-page :global(td) {
    color: var(--color-muted-text);
  }
</style>
