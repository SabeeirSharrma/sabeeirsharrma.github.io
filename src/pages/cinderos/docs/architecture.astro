---
import { getEntry, render } from 'astro:content';
import DocsLayout from '../../../layouts/DocsLayout.astro';

const entry = await getEntry('docs', 'cinderos/architecture');
if (!entry) throw new Error('Doc not found: cinderos/architecture');
const { Content } = await render(entry);
---

<DocsLayout title={entry.data.title} description={entry.data.description} project="cinderos">
  <Content />
</DocsLayout>
