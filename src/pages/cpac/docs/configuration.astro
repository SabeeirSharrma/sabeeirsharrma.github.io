---
import { getEntry, render } from 'astro:content';
import DocsLayout from '../../../layouts/DocsLayout.astro';

const entry = await getEntry('docs', 'cpac/configuration');
if (!entry) throw new Error('Doc not found: cpac/configuration');
const { Content } = await render(entry);
---

<DocsLayout title={entry.data.title} description={entry.data.description} project="cpac">
  <Content />
</DocsLayout>
