---
import MainLayout from '../../../../../layouts/MainLayout.astro';
---

<MainLayout title="Maintainer Panel" description="CPAC Trust DB — Maintainer Advisory Review">
  <div class="container mx-auto px-4 py-16 max-w-6xl">

    <!-- Auth Gate -->
    <div id="auth-gate" class="text-center py-20">
      <p class="text-muted-text">Checking access...</p>
    </div>

    <!-- Dashboard (hidden until auth) -->
    <div id="dashboard" class="hidden">

      <!-- Header -->
      <header class="mb-8 flex flex-wrap items-center justify-between gap-4">
        <div>
          <h1 class="text-3xl font-heading text-white uppercase tracking-widest">Maintainer Panel</h1>
          <p class="text-muted-text text-sm mt-1">Review and approve volunteer advisories</p>
        </div>
        <div class="flex items-center gap-4">
          <div class="text-right">
            <div class="text-xs text-muted-text">Pending review</div>
            <div class="text-lg font-heading text-ember-core" id="pending-count">0</div>
          </div>
          <button id="logoutBtn" class="text-xs text-muted-text hover:text-ember-core border border-border rounded-lg px-3 py-2 cursor-pointer transition-colors bg-surface">
            Sign Out
          </button>
        </div>
      </header>

      <!-- Tabs -->
      <div class="flex gap-1 mb-8 border-b border-border">
        <button id="tab-pending" class="tab-btn active" onclick="showTab('pending')">Pending Review</button>
        <button id="tab-published" class="tab-btn" onclick="showTab('published')">Published</button>
        <button id="tab-comparer" class="tab-btn" onclick="showTab('comparer')">Comparer</button>
        <button id="tab-stats" class="tab-btn" onclick="showTab('stats')">Stats</button>
        <button id="tab-volunteers" class="tab-btn" onclick="showTab('volunteers')">Volunteers</button>
      </div>

      <!-- Pending Tab -->
      <div id="panel-pending" class="tab-panel">
        <div id="pending-loading" class="text-center py-8 text-muted-text">Loading pending submissions...</div>
        <div id="pending-empty" class="hidden text-center py-8">
          <div class="text-5xl mb-3 opacity-30">✓</div>
          <p class="text-muted-text">No pending submissions</p>
        </div>
        <div id="pending-list" class="space-y-4"></div>
      </div>

      <!-- Published Tab -->
      <div id="panel-published" class="tab-panel hidden">
        <div id="published-loading" class="text-center py-8 text-muted-text">Loading published advisories...</div>
        <div id="published-list" class="space-y-3"></div>
      </div>

      <!-- Comparer Tab -->
      <div id="panel-comparer" class="tab-panel hidden">
        <div class="bg-surface border border-border rounded-xl p-6 mb-6">
          <h2 class="text-lg font-heading text-white mb-2 uppercase tracking-widest">Package Comparer</h2>
          <p class="text-sm text-muted-text mb-4">Compare two versions of a package PKGBUILD side-by-side with suspicious pattern detection.</p>

          <div class="relative mb-4">
            <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Package</label>
            <input type="text" id="m-pkgSearch" placeholder="Start typing a package name..."
              class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors" />
            <div id="m-pkgDropdown" class="hidden absolute z-20 w-full bg-base border border-border rounded-lg mt-1 max-h-48 overflow-y-auto shadow-lg"></div>
          </div>

          <div id="m-version-selectors" class="hidden">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">Old Version</label>
                <select id="m-versionOld" class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors"></select>
              </div>
              <div>
                <label class="block text-xs font-bold tracking-widest uppercase text-muted-text mb-1">New Version</label>
                <select id="m-versionNew" class="w-full bg-base border border-border rounded-lg px-4 py-3 text-white text-sm font-body outline-none focus:border-ember-core transition-colors"></select>
              </div>
            </div>
            <button id="m-compareBtn" class="bg-ember-core hover:bg-ember-deep text-white font-heading font-bold uppercase tracking-widest text-sm px-6 py-3 rounded-lg transition-colors cursor-pointer">Compare Versions</button>
          </div>
        </div>
        <div id="m-compare-loading" class="hidden text-center py-8 text-muted-text">Fetching PKGBUILDs and computing diff...</div>
        <div id="m-compare-error" class="hidden bg-red-900/20 border border-red-800 rounded-xl p-4 text-red-400 text-sm mb-6"></div>
        <div id="m-compare-result" class="hidden"></div>
      </div>

      <!-- Stats Tab -->
      <div id="panel-stats" class="tab-panel hidden">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="bg-surface p-4 rounded-lg border border-border text-center">
            <div class="text-3xl font-heading text-ember-core" id="stat-total">—</div>
            <div class="text-xs text-muted-text uppercase tracking-wider">Published</div>
          </div>
          <div class="bg-surface p-4 rounded-lg border border-border text-center">
            <div class="text-3xl font-heading text-ember-core" id="stat-pending">—</div>
            <div class="text-xs text-muted-text uppercase tracking-wider">Pending</div>
          </div>
          <div class="bg-surface p-4 rounded-lg border border-border text-center">
            <div class="text-3xl font-heading text-ember-core" id="stat-approved">—</div>
            <div class="text-xs text-muted-text uppercase tracking-wider">Approved Today</div>
          </div>
          <div class="bg-surface p-4 rounded-lg border border-border text-center">
            <div class="text-3xl font-heading text-ember-core" id="stat-rejected">—</div>
            <div class="text-xs text-muted-text uppercase tracking-wider">Rejected Today</div>
          </div>
        </div>
      </div>

      <!-- Volunteers Tab -->
      <div id="panel-volunteers" class="tab-panel hidden">
        <div id="vol-loading" class="text-center py-8 text-muted-text">Loading volunteer stats...</div>
        <div id="vol-empty" class="hidden text-center py-8">
          <p class="text-muted-text">No volunteers found.</p>
        </div>
        <div id="vol-list" class="space-y-3"></div>
      </div>

    </div>
  </div>

  <style>
    .tab-btn {
      padding: 0.75rem 1.5rem; font-family: var(--font-heading); font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.875rem;
      color: var(--color-muted-text); border-bottom: 2px solid transparent;
      transition: all 0.2s; cursor: pointer; background: none;
      border-top: none; border-left: none; border-right: none;
    }
    .tab-btn:hover { color: var(--color-ember-light); }
    .tab-btn.active { color: var(--color-ember-core); border-bottom-color: var(--color-ember-core); }
    .pending-card {
      background: var(--color-surface); border: 1px solid var(--color-border);
      border-radius: 0.5rem; padding: 1.25rem; transition: border-color 0.2s;
    }
    .pending-card:hover { border-color: var(--color-cinder-mid); }
    .severity-badge, .status-badge, .review-badge {
      display: inline-block; padding: 0.125rem 0.5rem; border-radius: 9999px;
      font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .severity-critical { background: #7f1d1d; color: #fca5a5; }
    .severity-high { background: #92400e; color: #fcd34d; }
    .severity-medium { background: #713f12; color: #fde68a; }
    .severity-low { background: #1e3a5f; color: #93c5fd; }
    .status-confirmed { background: #7f1d1d; color: #fca5a5; }
    .status-suspected { background: #713f12; color: #fde68a; }
    .review-pending { background: #713f12; color: #fde68a; }
    .review-approved { background: #14532d; color: #86efac; }
    .review-rejected { background: #7f1d1d; color: #fca5a5; }
    .action-btn {
      font-family: var(--font-heading); font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.05em; font-size: 0.75rem; padding: 0.5rem 1rem;
      border-radius: 0.5rem; cursor: pointer; transition: all 0.15s; border: none;
    }
    .pkg-option {
      padding: 0.5rem 0.75rem; cursor: pointer; font-size: 0.875rem;
      color: var(--color-muted-text); transition: background 0.15s;
    }
    .pkg-option:hover { background: var(--color-surface); color: var(--color-white); }
    .diff-line { font-family: 'SF Mono', 'Fira Code', monospace; font-size: 0.8rem; padding: 0.1rem 0.5rem; white-space: pre-wrap; word-break: break-all; }
    .diff-add { background: #14532d40; color: #86efac; }
    .diff-del { background: #7f1d1d40; color: #fca5a5; }
    .diff-ctx { color: var(--color-muted-text); }
    .diff-hunk { color: var(--color-ember-core); font-weight: 600; font-size: 0.75rem; padding: 0.3rem 0.5rem; background: var(--color-surface); }
    .vol-card {
      background: var(--color-surface); border: 1px solid var(--color-border);
      border-radius: 0.5rem; padding: 1rem 1.25rem; transition: border-color 0.2s;
    }
    .vol-card:hover { border-color: var(--color-cinder-mid); }
    .tier-badge {
      display: inline-block; padding: 0.15rem 0.6rem; border-radius: 9999px;
      font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    }
    .tier-trusted { background: #14532d; color: #86efac; }
    .tier-standard { background: #1e3a5f; color: #93c5fd; }
    .tier-probation { background: #713f12; color: #fde68a; }
    .tier-suspended { background: #7f1d1d; color: #fca5a5; }
  </style>

  <script is:inline>
    (function() {
      var SUPABASE_URL = 'https://qzhhsyucnlswmsvpssdh.supabase.co';
      var SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InF6aGhzeXVjbmxzd21zdnBzc2RoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI0NzE1NDQsImV4cCI6MjA5ODA0NzU0NH0.sIQobt0xfnMsgthGLJUb1S8f1yisDcavtRoWzi7y4OA';
      var supabase = null;
      var currentUser = null;
      var currentSession = null;

      var script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js';
      script.onload = init;
      document.head.appendChild(script);

      function init() {
        supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
        checkAuth();
      }

      function checkAuth() {
        supabase.auth.getSession().then(function(result) {
          if (!result.data.session) { window.location.href = '/cpac-trust-db/web/panel/login/'; return; }
          currentUser = result.data.session.user;
          currentSession = result.data.session;
          loadProfile();
        });
      }

      function loadProfile() {
        fetch(SUPABASE_URL + '/rest/v1/profiles?id=eq.' + currentUser.id + '&select=*', {
          headers: authHeaders()
        }).then(function(r) { return r.json(); }).then(function(data) {
          if (!data || data.length === 0 || data[0].role !== 'maintainer') {
            window.location.href = '/cpac-trust-db/web/panel/login/';
            return;
          }
          document.getElementById('auth-gate').classList.add('hidden');
          document.getElementById('dashboard').classList.remove('hidden');
          loadPending();
          loadPublished();
          loadStats();
        }).catch(function() { window.location.href = '/cpac-trust-db/web/panel/login/'; });
      }

      function anonHeaders() {
        return { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY };
      }

      function authHeaders() {
        return {
          'apikey': SUPABASE_KEY,
          'Authorization': 'Bearer ' + currentSession.access_token,
          'Content-Type': 'application/json'
        };
      }

      window.showTab = function(name) {
        document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.add('hidden'); });
        document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
        document.getElementById('panel-' + name).classList.remove('hidden');
        document.getElementById('tab-' + name).classList.add('active');
        if (name === 'volunteers') loadVolunteers();
      };

      // ── Load pending ──
      function loadPending() {
        fetch(SUPABASE_URL + '/rest/v1/pending_advisories?select=*,profiles:submitted_by(display_name)&review_status=eq.pending&order=created_at.asc', {
          headers: anonHeaders()
        }).then(function(r) { return r.json(); }).then(function(data) {
          document.getElementById('pending-loading').classList.add('hidden');
          document.getElementById('pending-count').textContent = data.length;

          if (data.length === 0) {
            document.getElementById('pending-empty').classList.remove('hidden');
            return;
          }

          var html = data.map(function(s) {
            var submitter = s.profiles ? s.profiles.display_name : 'Unknown';
            return '<div class="pending-card" id="pending-' + s.id + '">'
              + '<div class="flex flex-wrap items-center gap-2 mb-2">'
              + '<h3 class="text-lg font-heading text-white">' + s.package + '</h3>'
              + '<span class="severity-badge severity-' + s.severity + '">' + s.severity + '</span>'
              + '<span class="status-badge status-' + s.status + '">' + s.status + '</span>'
              + '<span class="text-xs text-muted-text ml-auto">by ' + submitter + ' — ' + new Date(s.created_at).toLocaleDateString() + '</span>'
              + '</div>'
              + '<p class="text-sm text-muted-text mb-3">' + s.summary + '</p>'
              + (s.description ? '<p class="text-xs text-muted-text mb-3 whitespace-pre-line">' + s.description + '</p>' : '')
              + (s.cve ? '<div class="text-xs text-muted-text mb-2">CVE: <span class="text-white">' + s.cve + '</span></div>' : '')
              + (s.affected_versions && JSON.parse(s.affected_versions).length > 0
                ? '<div class="text-xs text-muted-text mb-1">Affected: <span class="text-white">' + JSON.parse(s.affected_versions).join(', ') + '</span></div>' : '')
              + (s.safe_versions && JSON.parse(s.safe_versions).length > 0
                ? '<div class="text-xs text-muted-text mb-2">Safe: <span class="text-white">' + JSON.parse(s.safe_versions).join(', ') + '</span></div>' : '')
              + '<div class="flex gap-2 mt-3">'
              + '<button onclick="approveAdvisory(\'' + s.id + '\')" class="action-btn bg-green-800 hover:bg-green-700 text-green-100">Approve</button>'
              + '<button onclick="rejectAdvisory(\'' + s.id + '\')" class="action-btn bg-red-800 hover:bg-red-700 text-red-100">Reject</button>'
              + '</div>'
              + '<div id="action-msg-' + s.id + '" class="hidden text-xs mt-2"></div>'
              + '</div>';
          }).join('');
          document.getElementById('pending-list').innerHTML = html;
        });
      }

      window.approveAdvisory = async function(id) {
        var msgEl = document.getElementById('action-msg-' + id);
        msgEl.className = 'text-xs mt-2 text-green-400';
        msgEl.textContent = 'Approving...';

        try {
          var res = await fetch(SUPABASE_URL + '/rest/v1/rpc/approve_advisory', {
            method: 'POST',
            headers: authHeaders(),
            body: JSON.stringify({ p_pending_id: id, p_reviewed_by: currentUser.id, p_review_notes: '' })
          });

          if (res.ok) {
            msgEl.textContent = 'Approved and published!';
            setTimeout(function() { loadPending(); loadPublished(); loadStats(); }, 1000);
          } else {
            var err = await res.text();
            msgEl.className = 'text-xs mt-2 text-red-400';
            msgEl.textContent = 'Error: ' + err;
          }
        } catch (e) {
          msgEl.className = 'text-xs mt-2 text-red-400';
          msgEl.textContent = 'Network error: ' + e.message;
        }
      };

      window.rejectAdvisory = async function(id) {
        var notes = prompt('Rejection reason (optional):');
        var msgEl = document.getElementById('action-msg-' + id);
        msgEl.className = 'text-xs mt-2 text-yellow-400';
        msgEl.textContent = 'Rejecting...';

        try {
          var res = await fetch(SUPABASE_URL + '/rest/v1/rpc/reject_advisory', {
            method: 'POST',
            headers: authHeaders(),
            body: JSON.stringify({ p_pending_id: id, p_reviewed_by: currentUser.id, p_review_notes: notes || '' })
          });

          if (res.ok) {
            msgEl.textContent = 'Rejected.';
            setTimeout(function() { loadPending(); loadStats(); }, 1000);
          } else {
            var err = await res.text();
            msgEl.className = 'text-xs mt-2 text-red-400';
            msgEl.textContent = 'Error: ' + err;
          }
        } catch (e) {
          msgEl.className = 'text-xs mt-2 text-red-400';
          msgEl.textContent = 'Network error: ' + e.message;
        }
      };

      // ── Load published ──
      function loadPublished() {
        fetch(SUPABASE_URL + '/rest/v1/advisories?select=*&order=reported.desc', { headers: anonHeaders() })
          .then(function(r) { return r.json(); }).then(function(data) {
            document.getElementById('published-loading').classList.add('hidden');
            var html = data.map(function(a) {
              return '<div class="pending-card">'
                + '<div class="flex flex-wrap items-center gap-2 mb-1">'
                + '<span class="text-white font-bold">' + a.package + '</span>'
                + '<span class="severity-badge severity-' + a.severity + '">' + a.severity + '</span>'
                + '<span class="status-badge status-' + a.status + '">' + a.status + '</span>'
                + '</div>'
                + '<p class="text-sm text-muted-text">' + a.summary + '</p>'
                + '<div class="text-xs text-muted-text mt-1">By ' + a.reported_by + ' — ' + a.reported + '</div>'
                + '</div>';
            }).join('');
            document.getElementById('published-list').innerHTML = html;
          });
      }

      // ── Load stats ──
      function loadStats() {
        var today = new Date().toISOString().split('T')[0];
        Promise.all([
          fetch(SUPABASE_URL + '/rest/v1/advisories?select=id', { headers: anonHeaders() }).then(function(r) { return r.json(); }),
          fetch(SUPABASE_URL + '/rest/v1/pending_advisories?select=id&review_status=eq.pending', { headers: anonHeaders() }).then(function(r) { return r.json(); }),
          fetch(SUPABASE_URL + '/rest/v1/pending_advisories?select=id&review_status=eq.approved&reviewed_at=gte.' + today + 'T00:00:00', { headers: anonHeaders() }).then(function(r) { return r.json(); }),
          fetch(SUPABASE_URL + '/rest/v1/pending_advisories?select=id&review_status=eq.rejected&reviewed_at=gte.' + today + 'T00:00:00', { headers: anonHeaders() }).then(function(r) { return r.json(); })
        ]).then(function(results) {
          document.getElementById('stat-total').textContent = results[0].length;
          document.getElementById('stat-pending').textContent = results[1].length;
          document.getElementById('stat-approved').textContent = results[2].length;
          document.getElementById('stat-rejected').textContent = results[3].length;
        });
      }

      // ── Load volunteer reputation ──
      function loadVolunteers() {
        fetch(SUPABASE_URL + '/rest/v1/volunteer_reputation?select=*&order=total_submissions.desc', {
          headers: anonHeaders()
        }).then(function(r) { return r.json(); }).then(function(data) {
          document.getElementById('vol-loading').classList.add('hidden');
          if (!data || data.length === 0) {
            document.getElementById('vol-empty').classList.remove('hidden');
            return;
          }
          var html = data.map(function(v) {
            var tierClass = 'tier-' + (v.trust_tier || 'standard');
            var strikesColor = (v.strikes || 0) >= 2 ? 'text-red-400' : (v.strikes || 0) >= 1 ? 'text-yellow-400' : 'text-muted-text';
            return '<div class="vol-card">'
              + '<div class="flex flex-wrap items-center gap-4">'
              + '<div class="min-w-[140px]"><span class="text-white font-bold">' + (v.display_name || 'Unknown') + '</span></div>'
              + '<div><span class="tier-badge ' + tierClass + '">' + (v.trust_tier || 'standard') + '</span></div>'
              + '<div class="text-sm"><span class="text-muted-text">Rate:</span> <span class="text-white">' + (v.approval_rate || 0) + '%</span></div>'
              + '<div class="text-sm"><span class="text-muted-text">Submitted:</span> <span class="text-white">' + (v.total_submissions || 0) + '</span></div>'
              + '<div class="text-sm"><span class="text-muted-text">Approved:</span> <span class="text-green-400">' + (v.approved || 0) + '</span></div>'
              + '<div class="text-sm"><span class="text-muted-text">Rejected:</span> <span class="text-red-400">' + (v.rejected || 0) + '</span></div>'
              + '<div class="text-sm"><span class="text-muted-text">Strikes:</span> <span class="' + strikesColor + '">' + (v.strikes || 0) + '</span></div>'
              + '<div class="text-sm"><span class="text-muted-text">Active days:</span> <span class="text-white">' + (v.active_days || 0) + '</span></div>'
              + '</div></div>';
          }).join('');
          document.getElementById('vol-list').innerHTML = html;
        });
      }

      // ── Comparer (maintainer) ──
      var WORKER_BASE = 'https://api.thecinderproject.qd.je';
      var API_PREFIX = WORKER_BASE + '/cpac-trust-db/api';
      var mSearchTimeout = null;
      var mCurrentPkgData = null;

      var mPkgSearch = document.getElementById('m-pkgSearch');
      var mPkgDropdown = document.getElementById('m-pkgDropdown');

      mPkgSearch.addEventListener('input', function() {
        var q = mPkgSearch.value.trim();
        clearTimeout(mSearchTimeout);
        if (q.length < 2) { mPkgDropdown.classList.add('hidden'); return; }
        mSearchTimeout = setTimeout(function() { mSearchPackages(q); }, 300);
      });

      mPkgSearch.addEventListener('focus', function() {
        if (mPkgDropdown.children.length > 0 && mPkgSearch.value.trim().length >= 2) mPkgDropdown.classList.remove('hidden');
      });

      document.addEventListener('click', function(e) {
        if (!mPkgSearch.contains(e.target) && !mPkgDropdown.contains(e.target)) mPkgDropdown.classList.add('hidden');
      });

      async function mSearchPackages(q) {
        var html = '';
        try {
          var snapRes = await fetch(API_PREFIX + '/snapshots?select=package&package=like.' + encodeURIComponent(q) + '*&limit=10', { headers: anonHeaders() });
          var snaps = await snapRes.json();
          var dbPkgs = [...new Set(snaps.map(function(s) { return s.package; }))];
          dbPkgs.forEach(function(p) {
            html += '<div class="pkg-option" data-pkg="' + p + '">' + p + ' <span class="text-xs text-muted-text">(in DB)</span></div>';
          });
        } catch(e) {}
        try {
          var aurRes = await fetch(API_PREFIX + '/aur/info/' + encodeURIComponent(q));
          var aurData = await aurRes.json();
          if (aurData.results) {
            aurData.results.slice(0, 5).forEach(function(r) {
              if (!dbPkgs || dbPkgs.indexOf(r.Name) === -1) {
                html += '<div class="pkg-option" data-pkg="' + r.Name + '">' + r.Name + ' <span class="text-xs text-muted-text">(AUR)</span></div>';
              }
            });
          }
        } catch(e) {}
        if (!html) html = '<div class="pkg-option text-muted-text">No results</div>';
        mPkgDropdown.innerHTML = html;
        mPkgDropdown.classList.remove('hidden');
        mPkgDropdown.querySelectorAll('.pkg-option[data-pkg]').forEach(function(opt) {
          opt.addEventListener('click', function() { mSelectPackage(opt.dataset.pkg); mPkgDropdown.classList.add('hidden'); });
        });
      }

      async function mSelectPackage(pkg) {
        mPkgSearch.value = pkg;
        var loading = document.getElementById('m-compare-loading');
        var error = document.getElementById('m-compare-error');
        loading.classList.remove('hidden'); error.classList.add('hidden');
        try {
          var snapRes = await fetch(API_PREFIX + '/snapshots?select=*&package=eq.' + encodeURIComponent(pkg), { headers: anonHeaders() });
          var snapshots = await snapRes.json();
          var aurRes = await fetch(API_PREFIX + '/aur/info/' + encodeURIComponent(pkg));
          var aurData = await aurRes.json();
          mCurrentPkgData = { name: pkg, aurInfo: aurData.resultcount > 0 ? aurData.results[0] : null, snapshots: snapshots, versions: [...new Set(snapshots.map(function(s) { return s.version; }))] };
          if (mCurrentPkgData.aurInfo && mCurrentPkgData.versions.indexOf(mCurrentPkgData.aurInfo.Version) === -1) mCurrentPkgData.versions.push(mCurrentPkgData.aurInfo.Version);
          mCurrentPkgData.versions.sort();
          var oldSel = document.getElementById('m-versionOld');
          var newSel = document.getElementById('m-versionNew');
          oldSel.innerHTML = ''; newSel.innerHTML = '';
          mCurrentPkgData.versions.forEach(function(v) { oldSel.innerHTML += '<option value="' + v + '">' + v + '</option>'; newSel.innerHTML += '<option value="' + v + '">' + v + '</option>'; });
          if (mCurrentPkgData.versions.length >= 2) { oldSel.value = mCurrentPkgData.versions[mCurrentPkgData.versions.length - 2]; newSel.value = mCurrentPkgData.versions[mCurrentPkgData.versions.length - 1]; }
          document.getElementById('m-version-selectors').classList.remove('hidden');
          loading.classList.add('hidden');
        } catch(e) { error.textContent = 'Error: ' + e.message; error.classList.remove('hidden'); loading.classList.add('hidden'); }
      }

      document.getElementById('m-compareBtn').addEventListener('click', mRunCompare);

      async function mRunCompare() {
        if (!mCurrentPkgData) return;
        var vOld = document.getElementById('m-versionOld').value;
        var vNew = document.getElementById('m-versionNew').value;
        var loading = document.getElementById('m-compare-loading');
        var error = document.getElementById('m-compare-error');
        var result = document.getElementById('m-compare-result');
        loading.classList.remove('hidden'); error.classList.add('hidden'); result.classList.add('hidden');
        try {
          var oldText = null, newText = null;
          var oldSnap = mCurrentPkgData.snapshots.find(function(s) { return s.version === vOld && s.pkgbuild_text; });
          if (oldSnap) oldText = oldSnap.pkgbuild_text;
          var newSnap = mCurrentPkgData.snapshots.find(function(s) { return s.version === vNew && s.pkgbuild_text; });
          if (newSnap) newText = newSnap.pkgbuild_text;
          if (!newText && mCurrentPkgData.aurInfo && mCurrentPkgData.aurInfo.Version === vNew) {
            var res = await fetch(API_PREFIX + '/aur/pkgbuild/' + encodeURIComponent(mCurrentPkgData.name));
            newText = await res.text();
          }
          if (!oldText && !newText) { error.textContent = 'Could not fetch PKGBUILDs.'; error.classList.remove('hidden'); loading.classList.add('hidden'); return; }
          var diff = mComputeDiff(oldText || '', newText || '');
          var suspicious = mDetectSuspicious(newText || '');
          var advRes = await fetch(API_PREFIX + '/advisories?select=*&package=eq.' + encodeURIComponent(mCurrentPkgData.name), { headers: anonHeaders() });
          var advisories = await advRes.json();
          var advisory = advisories.length > 0 ? advisories[0] : null;
          mRenderResult(diff, suspicious, advisory, mCurrentPkgData.name, vOld, vNew, oldText, newText);
          loading.classList.add('hidden');
        } catch(e) { error.textContent = 'Error: ' + e.message; error.classList.remove('hidden'); loading.classList.add('hidden'); }
      }

      function mComputeDiff(oldText, newText) {
        var oldLines = oldText.split('\n'), newLines = newText.split('\n');
        var result = { lines: [], stats: { added: 0, removed: 0, unchanged: 0 } };
        var m = oldLines.length, n = newLines.length;
        var dp = Array.from({ length: m + 1 }, function() { return new Array(n + 1).fill(0); });
        for (var i = 1; i <= m; i++) for (var j = 1; j <= n; j++) dp[i][j] = oldLines[i-1] === newLines[j-1] ? dp[i-1][j-1] + 1 : Math.max(dp[i-1][j], dp[i][j-1]);
        i = m; j = n; var raw = [];
        while (i > 0 || j > 0) {
          if (i > 0 && j > 0 && oldLines[i-1] === newLines[j-1]) { raw.unshift({ type: 'ctx', text: oldLines[i-1] }); result.stats.unchanged++; i--; j--; }
          else if (j > 0 && (i === 0 || dp[i][j-1] >= dp[i-1][j])) { raw.unshift({ type: 'add', text: newLines[j-1] }); result.stats.added++; j--; }
          else { raw.unshift({ type: 'del', text: oldLines[i-1] }); result.stats.removed++; i--; }
        }
        result.lines = raw; return result;
      }

      function mDetectSuspicious(text) {
        var patterns = [
          { re: /curl\s+.*\|\s*(bash|sh)/i, label: 'curl pipe to shell', severity: 'high' },
          { re: /wget\s+.*\|\s*(sh|bash)/i, label: 'wget pipe to shell', severity: 'high' },
          { re: /\beval\b/i, label: 'eval usage', severity: 'high' },
          { re: /rm\s+-rf\s+[\/~]/i, label: 'Aggressive rm -rf', severity: 'high' },
          { re: /npm\s+install\s+.*\|\s*(bash|sh|node)/i, label: 'npm pipe to shell', severity: 'high' },
          { re: /npx\s+.*\|\s*(bash|sh)/i, label: 'npx pipe to shell', severity: 'high' },
          { re: /\\x[0-9a-f]{2}/i, label: 'Hex escape', severity: 'medium' },
          { re: /\bbase64\s+-d/i, label: 'Base64 decode', severity: 'medium' },
        ];
        var findings = [];
        text.split('\n').forEach(function(line, idx) {
          patterns.forEach(function(p) { if (p.re.test(line)) findings.push({ line: idx + 1, label: p.label, severity: p.severity }); });
        });
        return findings;
      }

      function mRenderResult(diff, suspicious, advisory, pkg, vOld, vNew, oldText, newText) {
        var el = document.getElementById('m-compare-result');
        var identical = diff.stats.added === 0 && diff.stats.removed === 0;
        var html = '<div class="bg-surface border border-border rounded-xl p-6">';
        html += '<div class="flex flex-wrap items-center gap-3 mb-4"><h3 class="text-xl font-heading text-white">' + pkg + '</h3>';
        html += identical ? '<span class="verdict-badge verdict-clean">IDENTICAL</span>' : suspicious.length > 0 ? '<span class="verdict-badge verdict-advisory">CHANGES</span>' : '<span class="verdict-badge verdict-outdated">MODIFIED</span>';
        html += '</div>';
        html += '<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4 text-sm">';
        html += '<div><span class="text-muted-text">Old:</span> <span class="text-white">' + vOld + '</span></div>';
        html += '<div><span class="text-muted-text">New:</span> <span class="text-white">' + vNew + '</span></div>';
        html += '<div><span class="text-muted-text">Added:</span> <span class="text-green-400">+' + diff.stats.added + '</span></div>';
        html += '<div><span class="text-muted-text">Removed:</span> <span class="text-red-400">-' + diff.stats.removed + '</span></div></div>';
        if (advisory) html += '<div class="bg-red-900/20 border border-red-800 rounded-lg p-3 text-sm mb-4"><span class="text-red-400 font-bold">Advisory:</span> ' + advisory.severity.toUpperCase() + ' — ' + advisory.summary + '</div>';
        if (suspicious.length > 0) {
          html += '<div class="bg-yellow-900/20 border border-yellow-800 rounded-lg p-3 text-sm mb-4"><span class="text-yellow-400 font-bold">Suspicious (' + suspicious.length + '):</span><ul class="mt-1">';
          suspicious.forEach(function(s) { html += '<li class="text-xs">[' + s.severity.toUpperCase() + '] Line ' + s.line + ': ' + s.label + '</li>'; });
          html += '</ul></div>';
        }
        if (!identical) {
          html += '<div class="border border-border rounded-lg overflow-hidden"><div class="diff-hunk">@@ Diff: ' + vOld + ' → ' + vNew + ' @@</div>';
          diff.lines.forEach(function(line) {
            if (line.type === 'ctx') return;
            var cls = line.type === 'add' ? 'diff-add' : 'diff-del';
            html += '<div class="diff-line ' + cls + '">' + (line.type === 'add' ? '+' : '-') + ' ' + escapeHtml(line.text) + '</div>';
          });
          html += '</div>';
        } else {
          html += '<div class="text-center py-6 text-muted-text text-sm">Identical — no changes.</div>';
        }
        html += '</div>';
        el.innerHTML = html; el.classList.remove('hidden');
      }

      document.getElementById('logoutBtn').addEventListener('click', function() {
        supabase.auth.signOut().then(function() { window.location.href = '/cpac-trust-db/web/panel/login/'; });
      });
    })();
  </script>
</MainLayout>
